generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ORGANIZER
  PARTICIPANT
}

enum MediaType {
  TEXT
  IMAGE
}

enum QuestionType {
  SINGLE
  MULTIPLE
}

enum ScoringMode {
  CORRECT_ONLY
  SPEED
}

enum QuizStatus {
  DRAFT
  PUBLISHED
}

enum SessionState {
  LOBBY
  QUESTION
  REVEAL
  FINISHED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  role         UserRole
  createdAt    DateTime @default(now())

  quizzes      Quiz[]
  participants QuizParticipant[]
}

model Quiz {
  id             String       @id @default(cuid())
  organizerId    String
  title          String
  description    String       @default("")
  category       String       @default("Общее")
  defaultTimeSec Int          @default(30)
  scoringMode    ScoringMode  @default(SPEED)
  status         QuizStatus   @default(DRAFT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organizer User          @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  questions Question[]
  sessions  QuizSession[]
}

model Question {
  id           String       @id @default(cuid())
  quizId       String
  orderIndex   Int
  type         QuestionType @default(SINGLE)
  mediaType    MediaType    @default(TEXT)
  text         String
  imageUrl     String?
  timeLimitSec Int
  points       Int          @default(1000)

  quiz    Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options AnswerOption[]
  answers SessionAnswer[]
}

model AnswerOption {
  id         String  @id @default(cuid())
  questionId String
  text       String
  imageUrl   String?
  isCorrect  Boolean @default(false)
  orderIndex Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizSession {
  id                   String        @id @default(cuid())
  quizId               String
  roomCode             String        @unique
  state                SessionState  @default(LOBBY)
  currentQuestionIndex Int           @default(-1)
  questionStartedAt    DateTime?
  startedAt            DateTime?
  finishedAt           DateTime?
  createdAt            DateTime      @default(now())

  quiz         Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  participants QuizParticipant[]
  answers      SessionAnswer[]
}

model QuizParticipant {
  id         String   @id @default(cuid())
  sessionId  String
  userId     String
  totalScore Int      @default(0)
  joinedAt   DateTime @default(now())

  session QuizSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers SessionAnswer[]

  @@unique([sessionId, userId])
}

model SessionAnswer {
  id                String   @id @default(cuid())
  sessionId         String
  questionId        String
  participantId     String
  selectedOptionIds String
  isCorrect         Boolean
  pointsEarned      Int      @default(0)
  responseTimeMs    Int      @default(0)
  answeredAt        DateTime @default(now())

  session     QuizSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question    Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  participant QuizParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId, participantId])
}
